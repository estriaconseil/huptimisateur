# Copier vers .env.local
#
# Supabase — https://supabase.com/dashboard/project/_/settings/api
#
# Nouveau modèle de clés (dashboard actuel) :
# - URL du projet : inchangée (https://<ref>.supabase.co)
# - « Publishable key » (préfixe sb_publishable_…) → variable ci‑dessous (ex‑anon, sûre avec RLS)
# - « Secret key » (préfixe sb_secret_…) → réservée backend uniquement (voir SUPABASE_SECRET_KEY)
#
NEXT_PUBLIC_SUPABASE_URL=
# Valeur = clé Publishable du dashboard (pas la Secret)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optionnel — clé Secret (sb_secret_…), uniquement serveur / scripts / Edge Functions.
# Ne jamais préfixer avec NEXT_PUBLIC ni l’exposer au navigateur.
# SUPABASE_SECRET_KEY=

# Google Maps — activer « Places API (New) » + « Distance Matrix API » (suggestions) ; facturation si requis.
# Autocomplete : PlaceAutocompleteElement (@googlemaps/js-api-loader). Suggestions : Distance Matrix côté serveur (même clé en MVP).
# https://console.cloud.google.com/apis/library
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
